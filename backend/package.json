{
    "name": "service-desk-backend",
    "version": "1.0.0",
    "description": "Service Desk Backend API with secure authentication",
    "main": "dist/app.js",
    "scripts": {
        "start": "node dist/app.js",
        "dev": "ts-node -r tsconfig-paths/register src/app.ts",
        "watch": "nodemon --exec ts-node -r tsconfig-paths/register src/app.ts",
        "build": "tsc && tsc-alias",
        "test": "jest"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "compression": "^1.7.4",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^16.0.3",
        "express": "^4.18.2",
        "express-rate-limit": "^6.7.0",
        "express-session": "^1.17.3",
        "express-validator": "^7.3.1",
        "helmet": "^6.1.5",
        "joi": "^17.9.1",
        "jsonwebtoken": "^9.0.0",
        "module-alias": "^2.3.4",
        "mongoose": "^7.0.3",
        "morgan": "^1.10.0",
        "redis": "^4.7.1"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.2",
        "@types/compression": "^1.7.2",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.25",
        "@types/express-session": "^1.17.7",
        "@types/joi": "^17.2.3",
        "@types/jsonwebtoken": "^9.0.2",
        "@types/mongoose": "^5.11.97",
        "@types/morgan": "^1.9.4",
        "@types/node": "^18.19.130",
        "jest": "^29.5.0",
        "nodemon": "^2.0.22",
        "supertest": "^6.3.3",
        "ts-node-dev": "^2.0.0",
        "tsc-alias": "^1.8.16",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.0.4"
    },
    "keywords": [
        "service-desk",
        "api",
        "authentication",
        "express"
    ],
    "author": "Service Desk Team",
    "license": "MIT"
